{
  "name": "slate-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force --skip-seed && npm run db:seed",
    "worker": "tsx src/workers/run.ts",
    "worker:all":    "tsx src/workers/run.ts all",
    "worker:soccer": "tsx src/workers/run.ts soccer",
    "worker:boxing": "tsx src/workers/run.ts boxing",
    "worker:mma":    "tsx src/workers/run.ts mma",
    "worker:nba":    "tsx src/workers/run.ts nba",
    "worker:nfl":    "tsx src/workers/run.ts nfl",
    "worker:mlb":    "tsx src/workers/run.ts mlb",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/compress": "^7.0.3",
    "@fastify/cors": "^9.0.1",
    "@fastify/etag": "^5.2.0",
    "@prisma/client": "^5.22.0",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
